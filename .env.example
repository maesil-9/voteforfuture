# PostgreSQL 연결 문자열 (Netlify DB의 NETLIFY_DATABASE_URL도 폴백 지원)
DATABASE_URL=postgres://vote:votepw_local@localhost:5436/voteforfuture

# 관리자/유권자 세션 쿠키 서명용 비밀키 (32바이트 hex 권장)
ADMIN_SESSION_SECRET=change-me-64-hex-chars

# 투표지(ballot) AES-256-GCM 봉인 키.
# 주의: 이 값을 분실하면 개표가 영구히 불가능하다.
RESULT_SEALING_KEY=change-me-64-hex-chars

# (선택) OG 메타데이터용 사이트 URL — Netlify는 URL 환경변수를 자동 제공
# NEXT_PUBLIC_SITE_URL=https://example.com
